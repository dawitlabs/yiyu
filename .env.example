DATABASE_URL=postgres://dawit:dawit@localhost:55432/yiyu?sslmode=disable

# S3-compatible object storage (MinIO locally; swap for R2/S3 in production
# by changing endpoint/credentials only — the client code doesn't change).
STORAGE_ENDPOINT=localhost:9002
STORAGE_ACCESS_KEY=dawit
STORAGE_SECRET_KEY=dawitdawit
STORAGE_BUCKET=yiyu-videos
STORAGE_PUBLIC_BASE_URL=http://localhost:9002/yiyu-videos
STORAGE_USE_SSL=false

# Auto-captions (optional) — unset means the worker skips auto-caption
# generation entirely. WHISPER_MODEL must point at a ggml model file
# (see https://github.com/ggml-org/whisper.cpp#quick-start).
WHISPER_BIN=whisper-cli
WHISPER_MODEL=

# Live streaming (optional) — backed by the mediamtx service in
# docker-compose.yml. MEDIAMTX_RTMP_SERVER (for OBS) and MEDIAMTX_WHIP_URL
# (for in-browser camera/screen broadcasting) are both public — creators'
# clients connect to them directly. MEDIAMTX_HLS_URL and MEDIAMTX_API_URL are
# internal — only cmd/api (HLS proxy) and cmd/worker (status poller) call
# them; in production these two ports should be firewalled off from the
# public internet. Leaving MEDIAMTX_API_URL unset disables the worker's
# live-status poller entirely.
MEDIAMTX_RTMP_SERVER=rtmp://localhost:1935/live
MEDIAMTX_WHIP_URL=http://localhost:8889
MEDIAMTX_HLS_URL=http://localhost:8888
MEDIAMTX_API_URL=http://localhost:9997
