API_URL=http://localhost:8082

# Client-visible mirror of API_URL, used only for the live chat WebSocket —
# that connects directly from the browser to the Go API (Next.js rewrites
# don't reliably forward WebSocket upgrades), so it can't go through the
# server-side API_URL/rewrite path like every other request does.
NEXT_PUBLIC_API_URL=http://localhost:8082
